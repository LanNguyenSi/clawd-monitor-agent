{
  "name": "clawd-monitor-agent",
  "version": "0.1.0",
  "description": "Lightweight agent that pushes OpenClaw instance data to clawd-monitor",
  "bin": {
    "clawd-monitor-agent": "./dist/cli.js"
  },
  "main": "./dist/agent.js",
  "files": [
    "dist",
    "install.sh",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LanNguyenSi/clawd-monitor-agent.git"
  },
  "homepage": "https://github.com/LanNguyenSi/clawd-monitor-agent#readme",
  "bugs": "https://github.com/LanNguyenSi/clawd-monitor-agent/issues",
  "keywords": [
    "openclaw",
    "monitoring",
    "agent",
    "clawd-monitor"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "overrides": {
    "postcss": "^8.5.10"
  }
}
